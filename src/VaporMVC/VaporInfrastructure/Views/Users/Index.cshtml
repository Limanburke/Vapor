@model IEnumerable<VaporDomain.Model.User>

@{
    ViewData["Title"] = "Керування користувачами";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h1 class="text-info m-0">Користувачі</h1>
</div>
<div class="card bg-transparent border-primary p-3 shadow-sm">
    <table class="table table-hover mb-0 align-middle">
        <thead>
            <tr class="table-primary">
                <th>@Html.DisplayNameFor(model => model.UserName)</th>
                <th>@Html.DisplayNameFor(model => model.Email)</th>
                <th>Статус</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                bool isLocked = item.LockoutEnd.HasValue && item.LockoutEnd.Value > DateTimeOffset.UtcNow;
                <tr>
                    <td class="fw-bold text-light"> @Html.DisplayFor(modelItem => item.UserName) </td>
                    <td class="text-info"> @Html.DisplayFor(modelItem => item.Email) </td>
                    <td>
                        @if (isLocked)
                        {
                            <span class="badge bg-danger">Заблокований</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Активний</span>
                        }
                    </td>
                    <td class="text-end text-nowrap">
                        <a asp-controller="Roles" asp-action="Edit" asp-route-userId="@item.Id" class="btn btn-sm btn-outline-warning me-2">Ролі</a>
                        <form asp-controller="Users" asp-action="ToggleBlock" method="post" class="d-inline">
                            <input type="hidden" name="Id" value="@item.Id" />
                            @if (isLocked)
                            {
                                <button type="submit" class="btn btn-sm btn-success">Розблокувати</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-outline-danger">Заблокувати</button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>