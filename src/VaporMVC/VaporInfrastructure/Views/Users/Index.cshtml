@model IEnumerable<VaporDomain.Model.User>

@{
    ViewData["Title"] = "Користувачі";
}

<h1 class="text-info">Користувачі</h1>
<div class="mt-3 mb-4">
    <a asp-action="Create" class="btn btn-primary">Створити нового користувача</a>
</div>
<div class="card bg-transparent border-primary p-3">
    <table class="table table-hover mb-0 align-middle">
        <thead>
            <tr class="table-primary">
                <th>@Html.DisplayNameFor(model => model.Username)</th>
                <th>@Html.DisplayNameFor(model => model.Email)</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold text-light"> @Html.DisplayFor(modelItem => item.Username) </td>
                    <td class="text-info"> @Html.DisplayFor(modelItem => item.Email) </td>
                    <td class="text-end text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Редагувати</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Деталі</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>