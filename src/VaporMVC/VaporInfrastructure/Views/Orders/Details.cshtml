@model VaporDomain.Model.Order

@{
    ViewData["Title"] = "Деталі замовлення";
}

<h1 class="text-info">
    Деталі чека
    <span class="text-light">#@Model.Id</span>
</h1>
<div class="row g-4 mt-2 mb-4">
    <div class="col-md-6">
        <div class="card border-info bg-transparent p-4 h-100">
            <h4 class="text-primary">Інформація</h4>
            <hr class="border-primary" />
            <dl class="row mb-0">
                <dt class="col-sm-4 text-info">@Html.DisplayNameFor(model => model.CreatedDate)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.CreatedDate)</dd>
                <dt class="col-sm-4 text-info">@Html.DisplayNameFor(model => model.User)</dt>
                <dd class="col-sm-8 fw-bold">@Html.DisplayFor(model => model.User.Email)</dd>
                <dt class="col-sm-4 text-info mt-3">@Html.DisplayNameFor(model => model.Status)</dt>
                <dd class="col-sm-8 mt-3">
                    @if (Model.StatusId == 1)
                    {
                        <span class="badge bg-warning text-dark fs-6">@Model.Status.Name</span>
                    }
                    else if (Model.StatusId == 2)
                    {
                        <span class="badge bg-success fs-6">@Model.Status.Name</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary fs-6">@Model.Status.Name</span>
                    }
                </dd>
            </dl>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-success bg-transparent p-4 h-100">
            <h4 class="text-success">Позиції в чеку</h4>
            <hr class="border-success" />
            @if (Model.OrderItems != null && Model.OrderItems.Any())
            {
                <ul class="list-group list-group-flush mb-4">
                    @foreach (var item in Model.OrderItems)
                    {
                        <li class="list-group-item bg-transparent text-light border-secondary px-0 d-flex justify-content-between align-items-center">
                            <span>@item.Game.Title</span>
                            <span class="text-success fw-bold">@item.Price$</span>
                        </li>
                    }
                </ul>
                <div class="d-flex justify-content-between align-items-center border-top border-success pt-3 mt-auto">
                    <span class="fs-5 text-light text-uppercase">Разом до сплати:</span>
                    <span class="fs-2 fw-bold text-success">@ViewBag.totalPrice$</span>
                </div>
            }
            else
            {
                <p class="text-muted fst-italic">Кошик порожній</p>
            }
        </div>
    </div>
</div>
<div>
    <a asp-action="Index" class="btn btn-secondary">Назад до списку</a>
</div>