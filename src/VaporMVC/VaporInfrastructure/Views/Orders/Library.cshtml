@model IEnumerable<VaporDomain.Model.Order>

@{
    ViewData["Title"] = "Моя бібліотека";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-info m-0">Моя бібліотека</h1>
    <span class="badge bg-primary fs-5 rounded-pill shadow-sm"> Ігор: @Model.SelectMany(o => o.OrderItems).Count() </span>
</div>
@if (!Model.Any() || !Model.SelectMany(o => o.OrderItems).Any())
{
    <div class="card bg-transparent border-secondary text-center py-5 mt-4 shadow-sm">
        <div class="card-body">
            <h2 class="text-muted mb-3">Ваша бібліотека порожня</h2>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg shadow"> Перейти до вітрини </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var order in Model.OrderByDescending(o => o.CreatedDate))
        {
            foreach (var item in order.OrderItems)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card bg-dark border-info h-100 shadow-sm" style="transition: transform 0.2s;">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-light fw-bold text-truncate" title="@item.Game.Title"> @item.Game.Title </h5>
                            <p class="text-muted small mt-auto mb-3">
                                Додано:
                                <span class="text-info"> @order.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm") </span>
                            </p>
                            <a asp-controller="Games" asp-action="Details" asp-route-id="@item.Game.Id" class="btn btn-outline-info w-100 mt-auto"> Деталі гри </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}