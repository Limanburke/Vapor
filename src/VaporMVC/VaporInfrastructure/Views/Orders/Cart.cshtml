@model VaporDomain.Model.Order

@{
    ViewData["Title"] = "Мій кошик";
}

<h1 class="text-info mb-4">Кошик покупок</h1>
@if (Model == null || Model.OrderItems == null || !Model.OrderItems.Any())
{
    <div class="card bg-transparent border-secondary text-center py-5 mt-4 shadow-sm">
        <div class="card-body">
            <h2 class="text-muted mb-3">Ваш кошик наразі порожній</h2>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg"> Перейти до вітрини </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card bg-transparent border-primary shadow-sm">
                <div class="card-header border-primary bg-primary text-white">
                    <h5 class="mb-0">Ігри у кошику (@Model.OrderItems.Count)</h5>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var item in Model.OrderItems)
                    {
                        <li class="list-group-item bg-transparent text-light border-secondary d-flex justify-content-between align-items-center p-3">
                            <div class="d-flex align-items-center">
                                <a asp-controller="Games" asp-action="Details" asp-route-id="@item.GameId" class="text-decoration-none text-light fs-5 fw-bold">
                                    @item.Game.Title </a>
                            </div>                          
                            <div class="d-flex align-items-center">
                                <span class="text-success fw-bold fs-4 me-4">@item.Price$</span>
                                <form asp-controller="Orders" asp-action="DeleteFromCart" asp-route-gameId="@item.GameId" method="post" class="m-0">
                                    <button type="submit" class="btn btn-outline-danger shadow-sm" title="Видалити з кошика"> Видалити </button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card bg-transparent border-success p-4 shadow-sm sticky-top" style="top: 20px;">
                <h4 class="text-success mb-3">Ваше замовлення</h4>
                <hr class="border-success" />
                <div class="d-flex justify-content-between mb-3 text-light">
                    <span>Дата формування:</span>
                    <span>@Html.DisplayFor(model => model.CreatedDate)</span>
                </div>
                <div class="d-flex justify-content-between mb-4">
                    <span class="text-light fs-5">Разом до сплати:</span>
                    <span class="text-success fw-bold fs-3">@ViewBag.totalPrice$</span>
                </div>
                <form asp-controller="Orders" asp-action="Checkout" asp-route-orderId="@Model.Id" method="post" class="w-100">
                    <button disabled="@ViewBag.hasOrderItems" type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow"> Оформити замовлення </button>
                </form>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-info w-100 mt-3"> Продовжити покупки </a>
            </div>
        </div>
    </div>
}