@model IEnumerable<VaporDomain.Model.Review>

@{
    ViewData["Title"] = "Відгуки";
}

<h1 class="text-info">Відгуки</h1>
<p class="mt-3 mb-4">
    <a asp-action="Create" class="btn btn-primary">Створити новий відгук</a>
</p>
<div class="card bg-transparent border-primary p-3">
    <table class="table table-hover mb-0">
        <thead>
            <tr class="table-primary">
                <th>@Html.DisplayNameFor(model => model.Content)</th>
                <th>@Html.DisplayNameFor(model => model.Raiting)</th>
                <th>@Html.DisplayNameFor(model => model.CreatedDate)</th>
                <th>@Html.DisplayNameFor(model => model.Game)</th>
                <th>@Html.DisplayNameFor(model => model.User)</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle text-truncate" style="max-width: 200px;"> @Html.DisplayFor(modelItem => item.Content) </td>
                    <td class="align-middle fw-bold text-warning"> ⭐ @Html.DisplayFor(modelItem => item.Raiting)/10 </td>
                    <td class="align-middle"> @Html.DisplayFor(modelItem => item.CreatedDate) </td>
                    <td class="align-middle"> @Html.DisplayFor(modelItem => item.Game.Title) </td>
                    <td class="align-middle"> @Html.DisplayFor(modelItem => item.User.Username) </td>
                    <td class="text-end align-middle">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Редагувати</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Деталі</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>