@model VaporDomain.Model.Review

@{
    ViewData["Title"] = "Створити";
}
@if (ViewBag.GameTitle != null)
{
    <h1>Додавання відгука до гри @ViewBag.GameTitle</h1>
}
else
{
    <h1>Створення відгука</h1>
}

<h4>Відгук</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                @if (ViewBag.IsContextual == true)
                {
                    <input type="hidden" value="@ViewBag.GameId" name="GameId" />
                }
                else
                {
                    <label asp-for="GameId" class="control-label"></label>
                    <select asp-for="GameId" class="form-control" asp-items="ViewBag.GameId"></select>
                }
            </div>
            <div class="form-group">
                <label asp-for="UserId" class="control-label"></label>
                <select asp-for="UserId" class="form-control" asp-items="ViewBag.UserId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Content" class="control-label"></label>
                <input asp-for="Content" class="form-control" />
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Raiting" class="control-label"></label>
                <input asp-for="Raiting" class="form-control" />
                <span asp-validation-for="Raiting" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CreatedDate" class="control-label"></label>
                <input asp-for="CreatedDate" class="form-control" />
                <span asp-validation-for="CreatedDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Створити" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Назад до списку</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
