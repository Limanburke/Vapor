@model VaporDomain.Model.Review

@{
    ViewData["Title"] = "Деталі відгуку";
}

<h1 class="text-info">Деталі</h1>
<div class="card border-info bg-transparent p-4 mb-4 mt-3">
    <h4 class="text-primary">Відгук</h4>
    <hr class="border-primary" />
    <dl class="row mb-0">
        <dt class="col-sm-2 text-info">@Html.DisplayNameFor(model => model.Game)</dt>
        <dd class="col-sm-10 fs-5">@Html.DisplayFor(model => model.Game.Title)</dd>
        <dt class="col-sm-2 text-info">@Html.DisplayNameFor(model => model.User)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.User.Username)</dd>
        <dt class="col-sm-2 text-info">@Html.DisplayNameFor(model => model.Raiting)</dt>
        <dd class="col-sm-10 text-warning fw-bold">⭐ @Html.DisplayFor(model => model.Raiting)/10</dd>
        <dt class="col-sm-2 text-info">@Html.DisplayNameFor(model => model.CreatedDate)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.CreatedDate)</dd>
        <dt class="col-sm-2 text-info mt-3">@Html.DisplayNameFor(model => model.Content)</dt>
        <dd class="col-sm-10 mt-3 border-start border-info ps-3 fst-italic"> "@Html.DisplayFor(model => model.Content)" </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Редагувати</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Назад до списку</a>
</div>