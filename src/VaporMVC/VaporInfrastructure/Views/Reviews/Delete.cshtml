@model VaporDomain.Model.Review

@{
    ViewData["Title"] = "Видалити відгук";
}

<h1 class="text-danger">Видалити</h1>
<h3 class="text-warning mb-4">Ви впевнені, що хочете видалити цей відгук?</h3>
<div class="card border-danger bg-transparent p-4 mb-4">
    <h4 class="text-info">Відгук</h4>
    <hr class="border-info" />
    <dl class="row mb-0">
        <dt class="col-sm-2 text-primary">@Html.DisplayNameFor(model => model.Game)</dt>
        <dd class="col-sm-10 fs-5">@Html.DisplayFor(model => model.Game.Title)</dd>
        <dt class="col-sm-2 text-primary">@Html.DisplayNameFor(model => model.User)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.User.Username)</dd>
        <dt class="col-sm-2 text-primary">@Html.DisplayNameFor(model => model.Rating)</dt>
        <dd class="col-sm-10 text-warning">⭐ @Html.DisplayFor(model => model.Rating)</dd>
        <dt class="col-sm-2 text-primary">@Html.DisplayNameFor(model => model.CreatedDate)</dt>
        <dd class="col-sm-10">@Model.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
        <dt class="col-sm-2 text-primary mt-2">@Html.DisplayNameFor(model => model.Content)</dt>
        <dd class="col-sm-10 mt-2 fst-italic">"@Html.DisplayFor(model => model.Content)"</dd>
    </dl>
</div>
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Видалити" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary ms-2">Назад до списку</a>
</form>