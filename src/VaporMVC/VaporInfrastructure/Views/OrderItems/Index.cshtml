@model IEnumerable<VaporDomain.Model.OrderItem>

@{
    ViewData["Title"] = "Позиції замовлень";
}

<h1 class="text-info">Позиції замовлень</h1>
<div class="alert alert-secondary bg-transparent border-secondary mt-3 mb-4" role="alert">
    <strong>Системний журнал:</strong>
    Позиції замовлень формуються автоматично при наповненні кошика покупцями. Ручне створення або редагування вимкнено для збереження цілісності фінансових даних.
</div>
<div class="card bg-transparent border-primary p-3">
    <table class="table table-hover mb-0">
        <thead>
            <tr class="table-primary">
                <th>Чек (ID)</th>
                <th>@Html.DisplayNameFor(model => model.Game)</th>
                <th>Фіксована ціна</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle fw-bold">
                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@item.Order.Id" class="text-decoration-none text-info"> #@Html.DisplayFor(modelItem => item.Order.Id) </a>
                    </td>
                    <td class="align-middle">
                        <a asp-controller="Games" asp-action="Details" asp-route-id="@item.Game.Id" class="text-decoration-none text-light"> @Html.DisplayFor(modelItem => item.Game.Title) </a>
                    </td>
                    <td class="align-middle text-success fw-bold fs-5"> @Html.DisplayFor(modelItem => item.Price) </td>
                </tr>
            }
        </tbody>
    </table>
</div>