@model VaporInfrastructure.ViewModel.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6 col-lg-5">
        <div class="card bg-dark border-primary shadow-lg" style="border-radius: 15px;">
            <div class="card-body p-4">
                <h2 class="text-center text-primary fw-bold mb-4" style="text-shadow: 0 0 10px rgba(13, 110, 253, 0.5);">Новий гравець</h2>
                <form method="post" asp-controller="Account" asp-action="Register">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-white fw-bold"></label>
                        <input asp-for="Email" class="form-control bg-secondary text-white border-0"/>
                        <span asp-validation-for="Email" class="text-warning"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label text-white fw-bold"></label>
                        <input asp-for="UserName" class="form-control bg-secondary text-white border-0"/>
                        <span asp-validation-for="UserName" class="text-warning"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label text-white fw-bold"></label>
                        <input asp-for="Password" class="form-control bg-secondary text-white border-0"/>
                        <span asp-validation-for="Password" class="text-warning"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="PasswordConfirm" class="form-label text-white fw-bold"></label>
                        <input asp-for="PasswordConfirm" class="form-control bg-secondary text-white border-0"/>
                        <span asp-validation-for="PasswordConfirm" class="text-warning"></span>
                    </div>
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary fw-bold fs-5">Зареєструватися</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}