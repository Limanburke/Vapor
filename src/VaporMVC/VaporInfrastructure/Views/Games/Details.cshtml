@model VaporDomain.Model.Game

@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-info display-4 fw-bold mb-0">@Model.Title</h1>
    <form asp-controller="Orders" asp-action="AddToCart" asp-route-gameId="@Model.Id" method="post" class="m-0">
        @if (ViewBag.hasOrderItems == true)
        {
            <button class="btn btn-lg btn-secondary" disabled type="button">Додано</button>
        }
        else
        {
            <button class="btn btn-lg btn-success shadow" type="submit">Покласти в кошик</button>
        }
    </form>
</div>
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card bg-transparent border-info h-100 p-4">
            <div class="mb-3">
                @if (Model.IsAvailable)
                {
                    <span class="badge bg-success fs-6 me-2">У продажу</span>
                }
                else
                {
                    <span class="badge bg-danger fs-6 me-2">Приховано</span>
                }
                <span class="text-muted">Дата релізу: @Html.DisplayFor(model => model.ReleasedDate)</span>
            </div>
            <h5 class="text-primary mt-2">Видавець</h5>
            <p class="fs-5">@Model.Publisher.Name</p>
            <h5 class="text-primary mt-2">Жанри</h5>
            <div class="mb-4">
                @if (Model.Genres.Any())
                {
                    @foreach (var genre in Model.Genres)
                    {
                        <span class="badge bg-secondary rounded-pill fs-6 fw-normal me-1 mb-1">@genre.Name</span>
                    }
                }
                else
                {
                    <span class="text-muted">Жанри не вказані</span>
                }
            </div>
            <h5 class="text-primary">Про гру</h5>
            <p class="fs-6" style="line-height: 1.6;"> @Html.DisplayFor(model => model.Description) </p>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card bg-transparent border-success p-4 mb-4 text-center">
            <h5 class="text-success mb-3">Поточна ціна</h5>
            <h2 class="display-5 fw-bold text-light">@Model.Price$</h2>
        </div>
        <div class="card bg-transparent border-warning p-4">
            <h5 class="text-warning mb-3">Історія цін</h5>
            @if (Model.PriceHistories.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var priceHist in Model.PriceHistories.OrderByDescending(p => p.ChangedData))
                    {
                        <li class="list-group-item bg-transparent text-light px-0 d-flex justify-content-between align-items-center border-secondary">
                            <span class="text-muted small">@priceHist.ChangedData</span>
                            <span>
                                <span class="text-decoration-line-through text-muted me-2">@priceHist.OldPrice$</span>
                                <span class="@(priceHist.NewPrice < priceHist.OldPrice ? "text-success" : "text-danger") fw-bold">@priceHist.NewPrice$</span>
                            </span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted mb-0">Ціна ще не змінювалася</p>
            }
        </div>
    </div>
</div>
<div class="card bg-transparent border-primary p-4 mt-4 mb-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div class="d-flex align-items-center flex-wrap gap-3">
            <h4 class="text-primary m-0">Відгуки користувачів</h4>
            @if (Model.Reviews.Any())
            {
                <div class="bg-warning text-dark px-3 py-1 rounded-pill fw-bold fs-5 shadow-sm">
                    ⭐ @Model.Reviews.Average(r => r.Raiting).ToString("0.0") / 10
                    <span class="fs-6 fw-normal ms-1">(@Model.Reviews.Count)</span>
                </div>
            }
            else
            {
                <span class="badge bg-secondary fs-6 rounded-pill">Немає оцінок</span>
            }
        </div>
        <a asp-controller="Reviews" asp-action="Create" asp-route-gameId="@Model.Id" class="btn btn-outline-primary shadow-sm"> Написати відгук </a>
    </div>
    @if (Model.Reviews.Any())
    {
        <div class="row g-3">
            @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedDate))
            {
                <div class="col-md-6">
                    <div class="card bg-dark border-secondary p-3 h-100 shadow-sm">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong class="text-info fs-5">@review.User.Username</strong>
                            <span class="badge border border-warning text-warning fs-6">⭐ @review.Raiting</span>
                        </div>
                        <div class="text-muted small mb-2">@review.CreatedDate.ToString("dd.MM.yyyy")</div>
                        <p class="mb-0 fst-italic text-light">"@review.Content"</p>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert border-secondary bg-transparent text-center p-4">
            <p class="text-muted fs-5 mb-0">Поки немає жодного відгуку</p>
        </div>
    }
</div>
<div class="mb-5">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Редагувати гру</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Назад до списку</a>
</div>