@model VaporDomain.Model.Game

@{
    ViewData["Title"] = "Редагувати гру";
}

<h1 class="text-info">Редагувати</h1>
<h4 class="text-primary mt-3">Гра</h4>
<hr class="border-primary" />
<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card bg-transparent border-info p-4 mb-4 shadow-sm">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="PublisherId" class="form-label text-info"></label>
                    <select asp-for="PublisherId" class="form-select" asp-items="ViewBag.PublisherId"></select>
                    <span asp-validation-for="PublisherId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Title" class="form-label text-info"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                <div class="mb-3 form-check form-switch fs-5">
                    <input class="form-check-input" type="checkbox" asp-for="IsAvailable" />
                    <label class="form-check-label text-info ms-2" asp-for="IsAvailable"> @Html.DisplayNameFor(model => model.IsAvailable) </label>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label text-info"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Price" class="form-label text-info"></label>
                    <div class="input-group">
                        <input asp-for="Price" type="number" step="0.01" class="form-control" />
                        <span class="input-group-text bg-secondary text-light border-secondary">$</span>
                    </div>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ReleasedDate" class="form-label text-info"></label>
                    <input asp-for="ReleasedDate" type="date" class="form-control" />
                    <span asp-validation-for="ReleasedDate" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label class="form-label text-info">Жанри</label>
                    <select name="Genres" class="form-select" asp-items="ViewBag.Genres" multiple="multiple" style="height: 150px;"></select>
                </div>
                <div class="mt-4">
                    <input type="submit" value="Зберегти зміни" class="btn btn-warning text-dark fw-bold btn-lg" />
                    <a asp-action="Index" class="btn btn-secondary ms-2">Назад до списку</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}