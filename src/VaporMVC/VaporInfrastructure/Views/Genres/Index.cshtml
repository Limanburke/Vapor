@model IEnumerable<VaporDomain.Model.Genre>

@{
    ViewData["Title"] = "Жанри";
}

<h1>Жанри</h1>
<p>
    <a asp-action="Create" class="btn btn-sm btn-outline-success">Створити жанр</a>
</p>
<table class="table table-hover mt-3">
    <thead>
        <tr class="table-primary">
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>Кількість ігор</th>
            <th class="text-end">Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="align-middle">@Html.DisplayFor(modelItem => item.Name)</td>
                <td class="align-middle">
                    <span class="badge bg-secondary rounded-pill">@item.Games.Count</span>
                </td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Редагувати</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Деталі</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>
