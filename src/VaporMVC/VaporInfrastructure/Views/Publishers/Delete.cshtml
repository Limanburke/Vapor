@model VaporDomain.Model.Publisher

@{
    ViewData["Title"] = "Видалити";
}

<h1 class="text-danger">Видалити</h1>
@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger shadow-sm" role="alert">
        <strong>Увага!</strong> @ViewBag.ErrorMessage
    </div>
}
<h3 class="text-warning mb-4">Ви впевнені, що хочете видалити видавника @ViewBag.PublisherName?</h3>
<div class="card border-danger bg-transparent p-4 mb-4">
    <h4 class="text-info">Видавець</h4>
    <hr class="border-info" />
    <dl class="row mb-0">
        <dt class="col-sm-2 text-primary"> @Html.DisplayNameFor(model => model.Name) </dt>
        <dd class="col-sm-10 fs-5"> @Html.DisplayFor(model => model.Name) </dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Видалити" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary ms-2">Назад до списку</a>
    </form>
</div>