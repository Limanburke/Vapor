@model IEnumerable<VaporDomain.Model.Game>

@{
    ViewData["Title"] = "Головна сторінка";
}

<div class="text-center mb-4">
    <h1 class="display-4 text-info fw-bold" style="text-shadow: 0 0 10px rgba(0, 255, 255, 0.5);">Vapor</h1>
</div>
@if (User.IsInRole("admin"))
{
    <details class="mb-5">
        <summary class="fs-4 text-primary fw-bold mb-3" style="cursor: pointer; list-style: none;">
            <span class="badge bg-primary rounded-pill me-2">~</span> Панель Адміністратора
        </summary>
        <div class="card bg-transparent border-primary p-4">
            <div class="row g-3">
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <a asp-controller="Publishers" asp-action="Index" class="btn btn-outline-info w-100">Видавники</a>
                </div>
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <a asp-controller="Games" asp-action="Index" class="btn btn-outline-info w-100">Ігри</a>
                </div>
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <a asp-controller="Genres" asp-action="Index" class="btn btn-outline-info w-100">Жанри</a>
                </div>
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <a asp-controller="Users" asp-action="Index" class="btn btn-outline-info w-100">Користувачі</a>
                </div>
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <a asp-controller="Reviews" asp-action="Index" class="btn btn-outline-info w-100">Відгуки</a>
                </div>
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <a asp-controller="PriceHistories" asp-action="Index" class="btn btn-outline-info w-100">Історія цін</a>
                </div>
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-info w-100">Замовлення</a>
                </div>
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <a asp-controller="OrderItems" asp-action="Index" class="btn btn-outline-info w-100">Позиції замовлень</a>
                </div>
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <a asp-controller="Status" asp-action="Index" class="btn btn-outline-info w-100">Статуси</a>
                </div>
            </div>
        </div>
    </details>
}
<form method="get" asp-action="Index" class="mb-4">
    <div class="input-group">
        <input type="text" name="searchString" class="form-control" placeholder="Пошук за назвою гри...">
        <select name="genreId" class="form-select" style="max-width: 200px;">
            <option value="">Усі жанри</option>
            @foreach (var genre in ViewBag.Genres)
            {
                <option value="@genre.Id">@genre.Name</option>
            }
        </select>
        <select name="publisherId" class="form-select" style="max-width: 200px;">
            <option value="">Усі видавці</option>
            @foreach (var publisher in ViewBag.Publishers)
            {
                <option value="@publisher.Id">@publisher.Name</option>
            }
        </select>
        <button type="submit" class="btn btn-primary">Шукати</button>
    </div>
</form>
<h2 class="mt-5 mb-3">Вітрина ігор</h2>
<div class="row">
    @foreach (var game in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 border border-info">
                @*<div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 200px;">
                    <span> Постер: @game.Title</span>
                </div>*@
                <div class="card-body">
                    <h5 class="card-title fw-bold">@game.Title</h5>
                    <p class="card-subtitle fs-5">@game.Publisher.Name</p>
                    <p class="card-text text-success fw-bold fs-5">@game.Price $</p>
                    <div class="mb-2 text-truncate">
                        @foreach (var genre in game.Genres)
                        {
                            <span class="badge bg-secondary rounded-pill fw-normal">@genre.Name</span>
                        }
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top-0 pb-3">
                    <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id" class="btn btn-primary w-100"> Детальніше </a>
                </div>
            </div>
        </div>
    }
    </div>
    <h2 class="mt-5 mb-4 text-info">Статистика магазину</h2>

    <div class="row mb-5">
        <div class="col-lg-4 col-md-12 mb-4">
            <div class="card bg-dark border-info shadow-sm">
                <div id="publisherChart" style="width: 100%; height: 350px;"></div>
            </div>
        </div>
        <div class="col-lg-4 col-md-12 mb-4">
            <div class="card bg-dark border-info shadow-sm">
                <div id="genreChart" style="width: 100%; height: 350px;"></div>
            </div>
        </div>
        <div class="col-lg-4 col-md-12 mb-4">
            <div class="card bg-dark border-success shadow-sm">
                <div class="card-header bg-transparent border-bottom border-success d-flex justify-content-between align-items-center">
                    <span class="text-success fw-bold">Рік:</span>
                    <form method="get" class="m-0">
                        <select name="year" class="form-select bg-dark text-white border-success form-select-sm" onchange="this.form.submit()">
                            @foreach (var y in ViewBag.Years)
                            {
                                if (y == ViewBag.SelectedYear)
                                {
                                    <option value="@y" selected>@y</option>
                                }
                                else
                                {
                                    <option value="@y">@y</option>
                                }
                            }
                        </select>
                    </form>
                </div>
                <div class="card-body p-0">
                    <div id="ordersChart" style="width: 100%; height: 310px;"></div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts
    {
        <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    
        <script type="text/javascript">
            google.charts.load('current', { 'packages': ['corechart'] });
            google.charts.setOnLoadCallback(drawAllCharts);

            function drawAllCharts() {
            drawPublisherChart();
            drawGenreChart();
            drawOrdersChart();
            }

            function drawPublisherChart() {
            fetch('/api/charts/countGameByPublisher')
            .then(response => response.json())
            .then(data => {
            const dataTable = new google.visualization.DataTable();
            dataTable.addColumn('string', 'Видавець');
            dataTable.addColumn('number', 'Кількість ігор');

            data.forEach(item => {
            dataTable.addRow([item.publisher, item.count]);
            });

            const options = {
            title: 'Ігри за видавцями',
            backgroundColor: 'transparent',
            titleTextStyle: { color: '#0dcaf0', fontSize: 18 },
            legend: { position: 'none' },
            hAxis: { textStyle: { color: '#fff' } },
            vAxis: { textStyle: { color: '#fff' } }
            };

            const chart = new google.visualization.ColumnChart(document.getElementById('publisherChart'));
            chart.draw(dataTable, options);
            });
            }

            function drawGenreChart() {
            fetch('/api/charts/countGameByGenre')
            .then(response => response.json())
            .then(data => {
            const dataTable = new google.visualization.DataTable();
            dataTable.addColumn('string', 'Жанр');
            dataTable.addColumn('number', 'Кількість ігор');

            data.forEach(item => {
            dataTable.addRow([item.genre, item.count]);
            });

            const options = {
            title: 'Популярність жанрів',
            backgroundColor: 'transparent',
            titleTextStyle: { color: '#0dcaf0', fontSize: 18 },
            legend: { textStyle: { color: '#fff' } },
            pieHole: 0.3
            };

            const chart = new google.visualization.PieChart(document.getElementById('genreChart'));
            chart.draw(dataTable, options);
            });
            }

            function drawOrdersChart() {
            fetch(`/api/charts/countOrdersByMonth?year=@ViewBag.SelectedYear`)
            .then(response => response.json())
            .then(data => {
            const dataTable = new google.visualization.DataTable();
            dataTable.addColumn('string', 'Місяць');
            dataTable.addColumn('number', 'Кількість замовлень');

            const monthNames = ['Січ', 'Лют', 'Бер', 'Кві', 'Тра', 'Чер', 'Лип', 'Сер', 'Вер', 'Жов', 'Лис', 'Гру'];

            for (let i = 0; i < 12; i++) {
            dataTable.addRow([monthNames[i], data[i]]);
            }

            const options = {
            title: 'Динаміка замовлень',
            backgroundColor: 'transparent',
            titleTextStyle: { color: '#198754', fontSize: 18 },
            legend: { position: 'none' },
            hAxis: { textStyle: { color: '#fff' } },
            vAxis: { textStyle: { color: '#fff' } },
            colors: ['#198754']
            };

            const chart = new google.visualization.LineChart(document.getElementById('ordersChart'));
            chart.draw(dataTable, options);
            });
            }
        </script>
    }
